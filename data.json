ficate_url": "https://www.coursera.org/account/accomplishments/certificate/2U9JQ8ZGJQGV", "certificate_image": "certifications/Screenshot_2026-05-26_150331.png", "issued_date": "2024-04-25", "display_order": 0, "created_at": "2026-05-26T09:33:59.882Z", "updated_at": "2026-05-26T09:33:59.882Z"}}, {"model": "core.certification", "pk": 5, "fields": {"name": "Generative AI with Large Language Models", "organization": "DeepLearning.AI", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/BH5JNMXMQZWE", "certificate_image": "certifications/Screenshot_2026-05-26_150452.png", "issued_date": "2024-04-30", "display_order": 0, "created_at": "2026-05-26T09:35:17.917Z", "updated_at": "2026-05-26T09:35:17.917Z"}}, {"model": "core.certification", "pk": 6, "fields": {"name": "ChatGPT Advanced Data Analysis", "organization": "Vanderbilt University", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/MRQY684XX5FE", "certificate_image": "certifications/Screenshot_2026-05-26_150633.png", "issued_date": "2024-04-30", "display_order": 0, "created_at": "2026-05-26T09:36:57.983Z", "updated_at": "2026-05-26T09:36:57.983Z"}}, {"model": "core.certification", "pk": 7, "fields": {"name": "ChatGPT Playground for Beginners: Intro to NLP AI", "organization": "Coursera", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/VE8EARWFC8NG", "certificate_image": "certifications/Screenshot_2026-05-26_150817.png", "issued_date": "2024-04-25", "display_order": 0, "created_at": "2026-05-26T09:38:44.945Z", "updated_at": "2026-05-26T09:38:44.945Z"}}, {"model": "core.certification", "pk": 8, "fields": {"name": "ChatGPT for Beginners: Save time with Microsoft Excel", "organization": "Coursera", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/8TA87EQPW2ST", "certificate_image": "certifications/Screenshot_2026-05-26_151038.png", "issued_date": "2024-04-25", "display_order": 0, "created_at": "2026-05-26T09:41:05.034Z", "updated_at": "2026-05-26T09:41:05.034Z"}}, {"model": "core.certification", "pk": 9, "fields": {"name": "Algorithms on Strings", "organization": "University of California San Diego", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/629NCZ7ZTSWG", "certificate_image": "certifications/Screenshot_2026-05-26_151216.png", "issued_date": "2024-04-03", "display_order": 0, "created_at": "2026-05-26T09:42:49.719Z", "updated_at": "2026-05-26T09:42:49.719Z"}}, {"model": "core.certification", "pk": 10, "fields": {"name": "Introduction to Large Language Models", "organization": "Google Cloud", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/RWF6THBL29NW", "certificate_image": "certifications/Screenshot_2026-05-26_151449.png", "issued_date": "2024-01-28", "display_order": 0, "created_at": "2026-05-26T09:45:11.118Z", "updated_at": "2026-05-26T09:45:11.118Z"}}, {"model": "core.certification", "pk": 11, "fields": {"name": "Prompt Engineering for ChatGPT", "organization": "Vanderbilt University", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/MLZ6MYGXWKPH", "certificate_image": "certifications/Screenshot_2026-05-26_151645.png", "issued_date": "2024-02-26", "display_order": 0, "created_at": "2026-05-26T09:47:25.545Z", "updated_at": "2026-05-26T09:47:25.545Z"}}, {"model": "core.certification", "pk": 12, "fields": {"name": "Generative AI Primer", "organization": "Vanderbilt University", "platform": "online", "certificate_url": "https://www.coursera.org/account/accomplishments/certificate/LL62JW3HS55R", "certificate_image": "certifications/Screenshot_2026-05-26_151918.png", "issued_date": "2024-01-28", "display_order": 0, "created_at": "2026-05-26T09:49:51.947Z", "updated_at": "2026-05-26T09:49:51.947Z"}}, {"model": "core.blogcategory", "pk": 1, "fields": {"name": "Django", "slug": "django", "description": "", "icon": ""}}, {"model": "core.blog", "pk": 1, "fields": {"title": "Understanding Django Templates: The Backbone of Dynamic Web Pages", "slug": "understanding-django-templates-the-backbone-of-dynamic-web-pages", "author": 1, "category": 1, "content": "When building web applications using Django, one of the most important concepts to understand is the Django Template System. Templates allow developers to create dynamic HTML pages by combining frontend design with backend data seamlessly.\r\n\r\nWhether you are building a portfolio website, blog platform, CMS, or e-commerce application, Django templates help you render data efficiently while keeping your code clean and organized.\r\n\r\nWhat Are Django Templates?\r\n\r\nA Django template is an HTML file that contains:\r\n\r\nStandard HTML\r\nCSS and JavaScript\r\nDynamic data from Django views\r\nSpecial Django Template Language (DTL) syntax\r\n\r\nTemplates make web pages dynamic.\r\n\r\nInstead of writing static HTML manually for every page, Django templates allow data to be injected directly from the backend.\r\n\r\nExample:\r\n\r\n<h1>{{ user.username }}</h1>\r\n\r\nHere, {{ user.username }} is dynamically replaced with actual user data.\r\n\r\nWhy Django Templates Are Important\r\n\r\nTemplates separate:\r\n\r\nBackend logic\r\nFrontend presentation\r\n\r\nThis follows DjangoΓÇÖs MVT (Model-View-Template) architecture.\r\n\r\nBenefits:\r\n\r\nCleaner codebase\r\nEasier maintenance\r\nBetter scalability\r\nFaster development\r\nReusable UI components\r\nDjango MVT Architecture\r\n\r\nDjango works using:\r\n\r\nModel ΓåÆ Database\r\nView ΓåÆ Business Logic\r\nTemplate ΓåÆ User Interface\r\n\r\nFlow:\r\n\r\nUser Request\r\n     Γåô\r\nDjango View\r\n     Γåô\r\nFetch Data from Model\r\n     Γåô\r\nSend Data to Template\r\n     Γåô\r\nRender HTML Response\r\nBasic Template Structure\r\n\r\nExample:\r\n\r\n<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>My Website</title>\r\n</head>\r\n<body>\r\n\r\n    <h1>Welcome {{ name }}</h1>\r\n\r\n</body>\r\n</html>\r\n\r\nIf the view sends:\r\n\r\ncontext = {\r\n    \"name\": \"Tanvir\"\r\n}\r\n\r\nOutput becomes:\r\n\r\n<h1>Welcome Tanvir</h1>\r\nRendering Templates in Views\r\n\r\nExample view:\r\n\r\nfrom django.shortcuts import render\r\n\r\ndef home(request):\r\n    context = {\r\n        \"name\": \"Tanvir\"\r\n    }\r\n    return render(request, \"index.html\", context)\r\n\r\nHere:\r\n\r\nindex.html is the template\r\ncontext contains dynamic data\r\nTemplate Tags in Django\r\n\r\nDjango templates support powerful template tags.\r\n\r\nVariables\r\n{{ variable }}\r\n\r\nExample:\r\n\r\n{{ post.title }}\r\nConditional Statements\r\n{% if user.is_authenticated %}\r\n    <p>Welcome back!</p>\r\n{% endif %}\r\nLoops\r\n{% for post in posts %}\r\n    <h2>{{ post.title }}</h2>\r\n{% endfor %}\r\n\r\nThis is commonly used in:\r\n\r\nblogs\r\nproduct listings\r\ndashboards\r\nCMS systems\r\nTemplate Inheritance\r\n\r\nOne of DjangoΓÇÖs most powerful features.\r\n\r\nInstead of repeating HTML across pages, you create a base template.\r\n\r\nbase.html\r\n<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>{% block title %}{% endblock %}</title>\r\n</head>\r\n<body>\r\n\r\n<nav>\r\n    Navbar\r\n</nav>\r\n\r\n{% block content %}\r\n{% endblock %}\r\n\r\n</body>\r\n</html>\r\nhome.html\r\n{% extends \"base.html\" %}\r\n\r\n{% block title %}\r\nHome\r\n{% endblock %}\r\n\r\n{% block content %}\r\n<h1>Homepage</h1>\r\n{% endblock %}\r\n\r\nBenefits:\r\n\r\nreusable layouts\r\nconsistent UI\r\neasier maintenance\r\nStatic Files in Templates\r\n\r\nDjango manages CSS, JS, and images using static files.\r\n\r\nExample:\r\n\r\n{% load static %}\r\n\r\n<link rel=\"stylesheet\" href=\"{% static 'css/style.css' %}\">\r\n\r\nThis helps organize frontend assets properly.\r\n\r\nWorking With Media Files\r\n\r\nFor uploaded images:\r\n\r\n<img src=\"{{ post.image.url }}\">\r\n\r\nUsed in:\r\n\r\ntravel websites\r\nCMS platforms\r\nblogs\r\ne-commerce systems\r\nDjango Template Filters\r\n\r\nFilters modify displayed data.\r\n\r\nExample:\r\n\r\n{{ name|upper }}\r\n\r\nOutput:\r\n\r\nTANVIR\r\n\r\nOther useful filters:\r\n\r\nlower\r\ntitle\r\ntruncatewords\r\ndate\r\nlength\r\nReusable Components Using Includes\r\n\r\nExample:\r\n\r\n{% include 'navbar.html' %}\r\n\r\nThis improves component reusability.\r\n\r\nCommon includes:\r\n\r\nnavbar\r\nfooter\r\nsidebar\r\ncards\r\nReal-World Use Cases\r\n\r\nDjango templates are widely used in:\r\n\r\nportfolio websites\r\nblogging systems\r\nadmin dashboards\r\nCMS applications\r\neducational portals\r\ntravel websites like VacayVibes\r\nAdvantages of Django Templates\r\nSimple Syntax\r\n\r\nEasy to learn for beginners.\r\n\r\nSecurity\r\n\r\nTemplates automatically escape dangerous HTML to help prevent XSS attacks.\r\n\r\nFast Development\r\n\r\nBuilt directly into Django.\r\n\r\nOrganized Structure\r\n\r\nSeparates backend and frontend cleanly.\r\n\r\nReusable Design\r\n\r\nInheritance and includes reduce repetition.\r\n\r\nLimitations of Django Templates\r\n\r\nAlthough powerful, Django templates are server-side rendered.\r\n\r\nModern frontend frameworks like:\r\n\r\nReact\r\nNext.js\r\nVue.js\r\n\r\noffer:\r\n\r\nhighly interactive UIs\r\nclient-side rendering\r\nSPA architecture\r\n\r\nThat is why many modern systems use:\r\n\r\nDjango REST API backend\r\nReact/Next.js frontend\r\n\r\nHowever, Django templates remain excellent for:\r\n\r\nsmall to medium projects\r\nCMS platforms\r\ndashboards\r\nadmin systems\r\nSEO-friendly websites\r\nBest Practices\r\nKeep Logic Minimal\r\n\r\nAvoid complex logic inside templates.\r\n\r\nUse Template Inheritance\r\n\r\nCreate reusable layouts.\r\n\r\nOrganize Templates Properly\r\n\r\nExample:\r\n\r\ntemplates/\r\n    base.html\r\n    blog/\r\n    users/\r\n    dashboard/\r\nOptimize Static Files\r\n\r\nCompress CSS and images for performance.\r\n\r\nConclusion\r\n\r\nDjango templates are one of the core features that make Django a powerful and developer-friendly framework. They allow developers to build dynamic, secure, and maintainable web applications efficiently.\r\n\r\nFor beginners entering backend or full-stack development, mastering Django templates is essential because they teach:\r\n\r\ndynamic rendering\r\nfrontend-backend integration\r\nreusable UI architecture\r\nscalable project organization\r\n\r\nEven in the era of modern frontend frameworks, Django templates continue to be highly relevant for fast, SEO-friendly, and production-ready web applications.", "excerpt": "", "featured_image": "blog/Vacayheroimgdesk.png", "meta_description": "", "meta_keywords": "", "is_published": true, "is_featured": true, "views": 1, "likes": 0, "published_at": "2026-05-25T15:51:56.233Z", "created_at": "2026-05-25T15:51:56.240Z", "updated_at": "2026-05-25T16:12:39.938Z"}}, {"model": "core.resume", "pk": 1, "fields": {"title": "Resume", "file": "resume/Resume26.pdf", "version": 1, "is_current": true, "uploaded_at": "2026-05-25T16:23:30.043Z", "updated_at": "2026-05-25T16:23:37.561Z"}}]
